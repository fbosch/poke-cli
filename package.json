{
  "name": "@fbb.sh/pkdx",
  "version": "0.3.0",
  "license": "MIT",
  "keywords": [
    "pokemon",
    "pokedex",
    "terminal",
    "cli",
    "tui"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fbosch/pkdx.git"
  },
  "imports": {
    "#src/*.ts": "./src/*.ts",
    "#src/*.tsx": "./src/*.tsx"
  },
  "files": [
    "bin/pkdx.mjs",
    "dist/pkdx-*"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "pkdx": "bin/pkdx.mjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "NODE_ENV=development bun run src/cli.tsx",
    "start": "bun run build && ./dist/pkdx",
    "build": "DEV=false bun build --compile --env='DEV*' --outfile=dist/pkdx src/cli.tsx",
    "analyze:bundle": "DEV=false bun build --target=bun --production --env='DEV*' --outdir=dist/analyze --metafile=dist/analyze/metafile.json --metafile-md=dist/analyze/metafile.md src/cli.tsx --external='@opentui/core-*'",
    "test": "bun test",
    "test:related": "bun run scripts/test-related.ts",
    "coverage:badge": "bun run scripts/generate-coverage-badge.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "fallow": "fallow --summary",
    "fallow:audit": "fallow audit --quiet",
    "bench": "bun run scripts/run-benchmarks.ts",
    "commitlint": "commitlint",
    "lint-staged": "lint-staged",
    "hooks:install": "lefthook install",
    "smoke:binary": "bun run scripts/smoke-binary.ts",
    "verify:release-package": "node scripts/verify-release-package.mjs",
    "check": "bun run format:check && bun run lint && bun run typecheck:native && bun test && bun run verify:index && bun run build && bun run fallow",
    "generate:index": "bun run scripts/generate-index.ts",
    "generate:pokeapi-types": "openapi-typescript https://raw.githubusercontent.com/PokeAPI/pokeapi/master/openapi.yml -o src/pokeapi/generated.ts && biome format --write src/pokeapi/generated.ts",
    "verify:index": "bun run scripts/verify-index.ts",
    "ci": "bun run check && bun run smoke:binary",
    "openspec": "openspec"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@fission-ai/openspec": "^1.4.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-reconciler": "^0.33.0",
    "@typescript/native-preview": "^7.0.0-dev.20260627.2",
    "fallow": "^2.103.0",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "@opentui/core": "^0.4.2",
    "@opentui/react": "^0.4.2",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "fuse.js": "^7.4.2",
    "react": "^19.2.7",
    "ts-pattern": "^5.9.0",
    "zod": "4.4.3"
  },
  "trustedDependencies": [
    "@fission-ai/openspec",
    "lefthook",
    "msw"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": [
      "biome format --write",
      "biome lint"
    ],
    "*.{ts,tsx}": "bun run test:related"
  }
}
