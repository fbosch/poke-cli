{
  "name": "poke-cli",
  "private": true,
  "type": "module",
  "bin": {
    "pokedex": "./src/cli.tsx"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --compile --outfile dist/pokedex --target bun-linux-x64",
    "test": "bun test",
    "test:related": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "fallow": "fallow --summary",
    "fallow:audit": "fallow audit --quiet",
    "commitlint": "commitlint",
    "lint-staged": "lint-staged",
    "hooks:install": "lefthook install",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun test && bun run verify:index && bun run build && bun run fallow",
    "generate:index": "bun run scripts/generate-index.ts",
    "verify:index": "bun run scripts/verify-index.ts",
    "ci": "bun run check",
    "openspec": "openspec"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@fission-ai/openspec": "^1.4.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-reconciler": "^0.33.0",
    "fallow": "^2.101.0",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "fuse.js": "^7.4.2",
    "react": "^19.2.7"
  },
  "trustedDependencies": [
    "@fission-ai/openspec",
    "lefthook"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,md}": "biome format --write",
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome lint",
    "*.{ts,tsx}": "bun run test:related"
  }
}
